        <mxCell id="1ctRIk5FABbpSJM_m1Ug-17" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;fontSize=9;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Tanım:&amp;nbsp;&lt;span style=&quot;font-weight: normal;&quot;&gt;Kulüp sistemine kayıtlı bireylerin kimlik, iletişim ve üyelik bilgilerini tutan veri yapısıdır.&lt;/span&gt;&lt;/h1&gt;" vertex="1">
